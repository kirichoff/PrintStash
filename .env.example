# Copy to .env and edit. NEVER commit .env.

# --- Storage Backend ---
# Choose "local" (default, files on local disk) or "s3" (S3-compatible object storage).
VAULT_STORAGE_BACKEND=local

# Local storage paths (used when backend=local). Defaults shown.
# VAULT_DATA_DIR=/data/files
# VAULT_THUMB_DIR=/data/thumbs

# Local staging directory for in-flight uploads (always local).
# VAULT_STAGING_DIR=/data/staging

# S3 / R2 config (used when VAULT_STORAGE_BACKEND=s3).
# VAULT_S3_BUCKET=my-vault-bucket
# VAULT_S3_ENDPOINT_URL=https://<accountid>.r2.cloudflarestorage.com
# VAULT_S3_REGION=auto
# VAULT_S3_ACCESS_KEY=your-access-key
# VAULT_S3_SECRET_KEY=your-secret-key
# Presigned URL TTL in seconds for direct downloads.
# VAULT_S3_PRESIGNED_URL_EXPIRE_SECONDS=900
# Multipart threshold in MB. Files larger than this use multipart transfer.
# VAULT_S3_MULTIPART_THRESHOLD_MB=50
# Optional lifecycle policy for the vault-data/* prefix.
# 0 disables each rule.
# VAULT_S3_LIFECYCLE_EXPIRATION_DAYS=0
# VAULT_S3_LIFECYCLE_TRANSITION_DAYS=0
# VAULT_S3_TRANSITION_STORAGE_CLASS=STANDARD_IA

# --- Database ---
# VAULT_DB_URL=sqlite:////data/db/printstash.sqlite
# Postgres (optional): use with `docker compose --profile postgres up -d`
# VAULT_DB_URL=postgresql://printstash:printstash@postgres:5432/printstash
# POSTGRES_DB=printstash
# POSTGRES_USER=printstash
# POSTGRES_PASSWORD=printstash

# --- Auth ---
# IMPORTANT: change BOTH secrets below before first start. The defaults are
# placeholders, not safe values — anyone who knows them can mint valid tokens.
# Generate strong random values, e.g.:  openssl rand -hex 32

# Shared API key for OrcaSlicer hooks and headless scripts.
# The VAULT_ prefix is retained for configuration compatibility.
VAULT_API_KEY=changeme

# JWT secret for user login tokens. Change this to a long random string.
VAULT_JWT_SECRET=changeme_jwt_secret_please_change
VAULT_JWT_ALGORITHM=HS256
VAULT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# Comma-separated browser origins allowed to call the API when the UI is hosted
# on a different origin. Defaults to local Vite dev origins only.
# VAULT_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# The first user (and storage paths, optionally) is created via the web-based
# first-run setup wizard at http://<host>:3000/setup — there is no env-driven
# default admin. Open the UI immediately after the first start.

VAULT_MAX_UPLOAD_MB=512
VAULT_LOG_LEVEL=INFO

# --- Backup ---
# Directory where tar.gz backup archives are stored.
# VAULT_BACKUP_DIR=/data/backups
# Number of days to retain backups before auto-purge (0 = keep forever).
# VAULT_BACKUP_RETENTION_DAYS=30

# --- Backup destination (optional cloud upload) ---
# Configure a separate S3/R2 bucket where backups are also uploaded.
# This is independent from the vault storage backend — you can keep
# vault data on local disk and upload backups to the cloud.
# VAULT_BACKUP_S3_BUCKET=my-backup-bucket
# VAULT_BACKUP_S3_ENDPOINT_URL=https://<id>.r2.cloudflarestorage.com
# VAULT_BACKUP_S3_REGION=auto
# VAULT_BACKUP_S3_ACCESS_KEY=backup-access-key
# VAULT_BACKUP_S3_SECRET_KEY=backup-secret-key

# --- MinIO (optional local S3-compatible target) ---
# Use with: docker compose --profile s3 up -d minio
# MINIO_ROOT_USER=minioadmin
# MINIO_ROOT_PASSWORD=minioadmin

# --- Frontend API/WebSocket base (advanced) ---
# The Docker Compose frontend is served by nginx, which proxies /api/v1 (incl.
# live-status WebSockets) to the api service on the SAME origin. In that setup
# you do NOT need to set anything here — leave these unset.
#
# Only set these for a split-origin deploy (UI and API on different hosts) or
# local Vite dev against a remote API. They are read at BUILD time by Vite, so
# rebuild the frontend image after changing them.
# VITE_API_URL=http://localhost:8000
# VITE_WS_URL=ws://localhost:8000
