# Copy to .env and edit. NEVER commit .env.

# Shared API key for OrcaSlicer hooks and headless scripts (Stage 1 compat).
VAULT_API_KEY=changeme

# JWT secret for user login tokens. Change this to a random string in production.
VAULT_JWT_SECRET=changeme_jwt_secret_please_change
VAULT_JWT_ALGORITHM=HS256
VAULT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# The first user (and storage paths, optionally) is created via the web-based
# first-run setup wizard at http://<host>:3000/setup — there is no env-driven
# default admin. Open the UI immediately after the first start.

VAULT_MAX_UPLOAD_MB=512
VAULT_LOG_LEVEL=INFO

# Browser-side WebSocket base for live printer status (Stage 3).
# Must be reachable from the user's browser — Next.js rewrites do not proxy WS.
NEXT_PUBLIC_WS_URL=ws://localhost:8000
